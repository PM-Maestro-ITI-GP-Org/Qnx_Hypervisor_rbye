From 3557110b697c531def886c1a1ee30bda6e91106c Mon Sep 17 00:00:00 2001
From: Mohamed100100 <muhammad.ahmed302@eng-st.cu.edu.eg>
Date: Sat, 18 Jul 2026 04:45:46 +0300
Subject: [PATCH] add the build files that will build the spi producer

---
 Makefile               | 15 +++++++++++++++
 QNX-SPI/.gitignore     |  1 +
 QNX-SPI/CMakeLists.txt | 12 ++++++++++++
 QNX-SPI/Makefile       | 19 +++++++++++++++++++
 4 files changed, 47 insertions(+)
 create mode 100644 Makefile
 create mode 100644 QNX-SPI/.gitignore
 create mode 100644 QNX-SPI/CMakeLists.txt
 create mode 100644 QNX-SPI/Makefile

diff --git a/Makefile b/Makefile
new file mode 100644
index 0000000..fedbf4b
--- /dev/null
+++ b/Makefile
@@ -0,0 +1,15 @@
+.PHONY: all qnx stm32 clean
+
+all: qnx
+
+qnx:
+	$(MAKE) -C QNX-SPI qnx
+
+stm32:
+	@echo "==> Building Stm32-SPI (PlatformIO)..."
+	$(MAKE) -C Stm32-SPI 2>/dev/null || \
+		pio run -d Stm32-SPI 2>/dev/null || \
+		echo "  (skip — install PlatformIO or add a Makefile to Stm32-SPI)"
+
+clean:
+	$(MAKE) -C QNX-SPI clean
diff --git a/QNX-SPI/.gitignore b/QNX-SPI/.gitignore
new file mode 100644
index 0000000..1a61b7e
--- /dev/null
+++ b/QNX-SPI/.gitignore
@@ -0,0 +1 @@
+build_qnx/
diff --git a/QNX-SPI/CMakeLists.txt b/QNX-SPI/CMakeLists.txt
new file mode 100644
index 0000000..7261530
--- /dev/null
+++ b/QNX-SPI/CMakeLists.txt
@@ -0,0 +1,12 @@
+cmake_minimum_required(VERSION 3.16)
+project(motor_data_producer LANGUAGES C)
+
+set(CMAKE_C_STANDARD 11)
+set(CMAKE_C_STANDARD_REQUIRED ON)
+
+include_directories(../../rpi-gpio/resmgr/public)
+
+add_executable(motor_data_producer
+    motor_controller.c config.c cJSON.c rpi_gpio.c rpi_spi.c
+)
+target_link_libraries(motor_data_producer PRIVATE m)
diff --git a/QNX-SPI/Makefile b/QNX-SPI/Makefile
new file mode 100644
index 0000000..f61b323
--- /dev/null
+++ b/QNX-SPI/Makefile
@@ -0,0 +1,19 @@
+QT6_DIR := ../../QT/qt6-qnx-libs/output_dir
+QNX800_DIR := ../../../qnx800
+
+.PHONY: all qnx clean
+
+all: qnx
+
+qnx:
+	@[ -n "$(QNX_HOST)" ] || [ -f "$(QNX800_DIR)/qnxsdp-env.sh" ] || { echo "QNX SDP not found at $(QNX800_DIR)/qnxsdp-env.sh"; exit 1; }
+	@bash -c 'set -e; \
+		[ -n "$$QNX_HOST" ] || . "$(QNX800_DIR)/qnxsdp-env.sh"; \
+		cmake -S . -B build_qnx \
+			-DCMAKE_BUILD_TYPE=Release \
+			-DCMAKE_TOOLCHAIN_FILE=$(QT6_DIR)/lib/cmake/Qt6/qt.toolchain.cmake \
+			-DQNX_LIB_DIR=$(QNX800_DIR)/target/qnx/aarch64le; \
+		cmake --build build_qnx'
+
+clean:
+	rm -rf build_qnx
-- 
2.34.1

