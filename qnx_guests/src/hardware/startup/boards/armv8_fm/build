[+keeplinked]
[image=0x80000000]
[virtual=aarch64le,elf] .bootstrap = {
	#
	# board_smp.c requires -Px to specify how many processors are present.
	# This should be <= number of processors configured in the model.
	# eg. Foundation_v8 --cores=2 --image <image_ifs>
	#
	startup-armv8_fm -vv -P2

	PATH=/proc/boot LD_LIBRARY_PATH=/proc/boot procnto-smp-instr -vv
}

[+script] .script = {
	display_msg Welcome to QNX 7.0.0 on the ARMv8 Foundation Model

	procmgr_symlink ../../proc/boot/ldqnx-64.so.2 /usr/lib/ldqnx-64.so.2

	devc-serpl011 -F -e 0x1c090000,37 &
	reopen /dev/ser1

	[+session] ksh &
}

