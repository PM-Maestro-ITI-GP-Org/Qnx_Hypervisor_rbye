################################################################################################
## virtio-gpu guest driver over MMIO (talks to host vdev-virtio-gpu.so)
##  - drm-virtio attaches to the MMIO virtio-gpu vdev (NO PCI); creates /dev/dri/card0
##  - screen -c graphics-virtio-mmio.conf brings up /dev/screen (Mesa virgl GL)
##  - run /scripts/graphics-virtio-start.sh from the guest shell (or customize_startup.sh)
################################################################################################
/usr/share/screen/graphics-virtio-mmio.conf=../../../conf/display/graphics-virtio-mmio.conf

# Referenced as an external file (not an inline "= { }" block): mkifs ends an inline
# block at the first '}', which a shell script's ${brace} expansions would trip.
[perms=0755] /scripts/graphics-virtio-start.sh=../../../conf/display/graphics-virtio-start.sh