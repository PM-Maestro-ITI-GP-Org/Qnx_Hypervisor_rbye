diff --git a/src/vrend/vrend_winsys.c b/src/vrend/vrend_winsys.c
index d4c9b9e..9cfcb78 100644
--- a/src/vrend/vrend_winsys.c
+++ b/src/vrend/vrend_winsys.c
@@ -60,7 +60,14 @@ int vrend_winsys_init(uint32_t flags, int preferred_fd)
        * If the user specifies a preferred DRM fd and we can't use it, fail. If the user doesn't
        * specify an fd, it's possible to initialize EGL without one.
        */
-      gbm = virgl_gbm_init(preferred_fd);
+      /* QNX: the generic gbm/dri (MESA-LOADER) device query crashes on QNX's DRM.
+       * When surfaceless with no caller-provided fd, skip gbm entirely and use pure
+       * EGL surfaceless (EGL_PLATFORM_SURFACELESS_MESA, or the Screen default display
+       * fallback) -- QNX provides EGL_EXT_platform_base. */
+      if (preferred_fd < 0 && (flags & VIRGL_RENDERER_USE_SURFACELESS))
+         gbm = NULL;
+      else
+         gbm = virgl_gbm_init(preferred_fd);
       if (preferred_fd > 0 && !gbm)
          return -1;
 
diff --git a/src/vrend/vrend_winsys_egl.c b/src/vrend/vrend_winsys_egl.c
index 0c99219..5ef31a6 100644
--- a/src/vrend/vrend_winsys_egl.c
+++ b/src/vrend/vrend_winsys_egl.c
@@ -347,7 +347,9 @@ struct virgl_egl *virgl_egl_init(EGLNativeDisplayType display_id, bool surfacele
       goto fail;
 
 #ifdef ENABLE_GBM_ALLOCATION
-   if (virgl_egl_get_display(egl)) {
+   /* QNX: with no gbm device (pure surfaceless), skip the gbm-device query path
+    * (it dereferences egl->gbm) and fall through to EGL surfaceless below. */
+   if (egl->gbm && virgl_egl_get_display(egl)) {
      /* Make -Wdangling-else happy. */
    } else /* Fallback to surfaceless. */
 #endif
diff --git a/src/vrend/vrend_winsys_gbm.c b/src/vrend/vrend_winsys_gbm.c
