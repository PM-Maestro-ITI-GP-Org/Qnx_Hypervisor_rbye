-    SIGEV_PULSE_INIT(&msg.event, event_coid, -1, _PULSE_CODE_MINAVAIL, gpio);
-    if (MsgRegisterEvent(&msg.event, gpio_fd) == -1) {
-        set_error("RPI_GPIO_ADD_EVENT: %s", strerror(errno));
-        return NULL;
-    }
