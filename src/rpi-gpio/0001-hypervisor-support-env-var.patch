-static PyObject *
-rpi_gpio_add_event(PyObject *self, PyObject *args, PyObject *kwargs)
-{
-    static char *kwlist[] = {
-        "gpio",
-        "edge",
-        "match",
-        "callback",
-        NULL
-    };
-
-    unsigned    gpio;
-    unsigned    edge;
-    unsigned    match = 1;
