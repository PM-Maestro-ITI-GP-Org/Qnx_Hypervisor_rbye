-static PyObject *
-rpi_gpio_write_spi(PyObject *self, PyObject *args)
-{
-    PyObject *dataList;
-    if (!PyArg_ParseTuple(args, "O!", &PyList_Type, &dataList)) {
-        return NULL;
-    }
-
-    uint8_t data[256];
-    size_t const    size = PyList_Size(dataList);
-    if (size > sizeof(data)) {
-        set_error("List has too many members: %zu. Max is %zu", size, sizeof(data));
-        return NULL;
-    }
-
-    for (size_t i = 0; i < size; i++) {
-        PyObject * const    obj = PyList_GetItem(dataList, i);
-        if (obj == NULL) {
-            set_error("Bad list item: %zu", i);
-            return NULL;
-        }
-        data[i] = PyLong_AsLong(obj);
-    }
-
-    // Try to connect to the desired device. Since this API doesn't
-    // allow a specific chip-select, connect to dev0
-    if (spi_fds[0] == -1 && init_spi_device(0)) {
-        return NULL;
-    }
-
-    if (write(spi_fds[0], data, size) == -1) {
-        set_error("Failed to write %zu bytes: %s", size, strerror(errno));
-        return NULL;
-    }
-
-    Py_RETURN_NONE;
-}
-
-static PyObject *
-rpi_gpio_write_read_spi(PyObject *self, PyObject *args)
-{
-    struct {
-        spi_xchng_t  msg;
-        uint8_t      data[256];
-    } smsg;
-
-    unsigned    cs;
-    PyObject   *inDataList;
-    PyObject   *outDataList;
-    if (!PyArg_ParseTuple(args, "IO!O!", &cs, &PyList_Type, &inDataList,
-                          &PyList_Type, &outDataList)) {
-        return NULL;
-    }
-
-    if (cs >= sizeof(spi_fds)/sizeof(spi_fds[0])) {
-        set_error("SPI cs/device is out of range: %u", cs);
-        return NULL;
-    }
-
-    size_t const    inSize = PyList_Size(inDataList);
-    if (inSize > sizeof(smsg.data)) {
-        set_error("Input list has too many members: %zu. Max is %zu", inSize, sizeof(smsg.data));
-        return NULL;
-    }
-
-    size_t const    outSize = PyList_Size(outDataList);
-    if (outSize > sizeof(smsg.data)) {
-        set_error("Output list has too many members: %zu. Max is %zu", outSize, sizeof(smsg.data));
-        return NULL;
-    } else if (outSize > inSize) {
-        set_error("Output list length MUST be less or equal to length of input list");
-        return NULL;
-    }
-
-    for (size_t i = 0; i < inSize; i++) {
-        PyObject * const    obj = PyList_GetItem(inDataList, i);
-        if (obj == NULL) {
-            set_error("Bad list item: %zu", i);
-            return NULL;
-        }
-        smsg.data[i] = PyLong_AsLong(obj);
-    }
-    smsg.msg.nbytes = inSize;
-
-    // Try to connect to the desired device.
-    if (spi_fds[cs] == -1 && init_spi_device(cs)) {
-        return NULL;
-    }
-
-    // Do the data xchange
-    int err = devctl(spi_fds[cs], DCMD_SPI_DATA_XCHNG, &smsg, sizeof(spi_xchng_t) + inSize, NULL);
-    if (err != EOK)
-    {
-        set_error("Unable to read/write data. Error=%s", strerror(err));
-        return NULL;
-    }
-
-    for (size_t i = 0; i < outSize; i++) {
-        PyObject * const    obj = PyLong_FromLong(smsg.data[i]);
-        if (obj == NULL) {
-            set_error("Failed to convert result");
-            return NULL;
-        }
-        PyList_SetItem(outDataList, i, obj);
-    }
-
-    Py_RETURN_NONE;
-}
-
-static PyObject *
-rpi_gpio_cleanup(PyObject *self, PyObject *args)
-{
-    unsigned i;
-    for (i = 0; i < sizeof(spi_fds)/sizeof(spi_fds[0]); ++i) {
-        if (spi_fds[i] != -1) {
-            close(spi_fds[i]);
-            spi_fds[i] = -1;
-        }
-    }
-    close(gpio_fd);
-    Py_RETURN_NONE;
-}
