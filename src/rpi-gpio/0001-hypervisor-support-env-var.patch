-        PyErr_Format(PyExc_OverflowError, "Response can have at most %u elements. Has %u elements", max_bytes, nbytes);
-        return NULL;
-    }
-    list = PyList_New(nbytes);
-    if (list == NULL) {
-        PyErr_SetString(PyExc_MemoryError, "Unable to make return list");
-        return NULL;
-    }
-    for (int i = 0; i < nbytes; ++i) {
-        PyList_SET_ITEM(list, i, Py_BuildValue("l", (long)buffer[i]));
-    }
-
-    return list;
-}
