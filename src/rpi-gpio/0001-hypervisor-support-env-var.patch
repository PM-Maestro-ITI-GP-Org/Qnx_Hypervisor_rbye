-static int smbus_qnx_open_bus(smbus_qnx_t *self, int bus) {
-    int fd;
-    char buffer[128];
-
-    if (bus < 0) {
-        PyErr_SetString(PyExc_ValueError, "Invalid bus. Must be >= 0");
-        return -1;
-    }
-
-    // Allow the same bus to be re-opened, fail if something different was requested
-    if (self->fd == -1) {
-        snprintf(buffer, sizeof(buffer), "/dev/i2c%d", bus);
-        fd = open(buffer, O_RDWR, 0);
-        if (fd == -1) {
-            PyErr_SetFromErrno(PyExc_IOError);
-            return -1;
-        }
-
-        self->bus = bus;
-        self->fd = fd;
-    } else if (self->bus != bus) {
-        PyErr_SetString(PyExc_RuntimeError, "Already opened");
-        return -1;
-    }
-
-    return 0;
-}
-
-static ssize_t smbus_qnx_parse_list(PyObject *list, uint8_t *buffer, size_t buffer_size) {
-    ssize_t len;
-    ssize_t i;
-    PyObject *value;
-
-    len = PyList_GET_SIZE(list);
-    if (len > (ssize_t)buffer_size) {
-        PyErr_Format(PyExc_OverflowError, "List can have at most %u elements. Has %u elements", buffer_size, len);
-        return -1;
-    }
-
-    for (i = 0; i < len; ++i) {
-        value = PyList_GET_ITEM(list, i);
-        if (!PyLong_Check(value)) {
-            PyErr_Format(PyExc_TypeError, "List elements must be integers. Element %u is not.", i);
-            return -1;
-        }
-        buffer[i] = (uint8_t)PyLong_AS_LONG(value);
-    }
-
-    return len;
-}
