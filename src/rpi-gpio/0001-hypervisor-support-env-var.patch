-static int
-init_event_thread()
-{
-    pthread_t   tid;
-    sem_t       sem;
-
-    sem_init(&sem, 0, 0);
-
-    // Create the event receiving thread.
-    if (pthread_create(&tid, NULL, event_thread, &sem) != 0) {
-        set_error("Failed to create event thread");
-        return 0;
-    }
-
-    // Wait for the thread to establish the self connection.
-    sem_wait(&sem);
-    if (event_coid == -1) {
-        set_error("Failed to create event thread");
-        return 0;
-    }
-
-    return 1;
-}
