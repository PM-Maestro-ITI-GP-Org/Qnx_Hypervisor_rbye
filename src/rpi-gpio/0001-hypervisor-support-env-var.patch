-static int smbus_qnx_set_bus(smbus_qnx_t *self, PyObject *value, void *closure) {
-    // Bus must be an integer
-    if (value == NULL) {
-        PyErr_SetString(PyExc_TypeError, "Cannot delete bus");
-        return -1;
-    }
-    if (!PyNumber_Check(value)) {
-        PyErr_SetString(PyExc_TypeError, "Bus must be integer");
-        return -1;
-    }
-    Py_ssize_t new_bus = PyNumber_AsSsize_t(value, PyExc_OverflowError);
-    if (new_bus == -1) return -1;
-
-    // Can't set the bus if we are already connected
-    if (self->fd != -1) {
-        PyErr_SetString(PyExc_RuntimeError, "Unable to set bus once opened");
-        return -1;
-    }
-
-    self->bus = (int)new_bus;
-    return 0;
-}
