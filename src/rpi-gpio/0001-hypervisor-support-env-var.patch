-static int init_spi_device(unsigned dev) {
-    int err;
-    int fd = -1;
-
-    if (dev >= sizeof(spi_fds)/sizeof(spi_fds[0])) {
-        set_error("SPI cs/device is out of range: %u", dev);
-        return EINVAL;
-    } else if (spi_fds[dev] != -1) {
-        set_error("SPI cs/device %u is already connected", dev);
-        return EBUSY;
-    } else if (spi_clkdiv == 0) {
-        set_error("SPI has not yet been initialized");
-        return EINVAL;
-    }
-
-    char path[256];
-    snprintf(path, sizeof(path), "%sspi0/dev%u", IOSPI_DEV_PATH, dev);
-
-    // Connect to the device
-    fd = open(path, O_RDWR);
-    if (fd == -1) {
-        err = errno;
-        set_error("SPI is unable to connect to %s. Error=%s", path, strerror(err));
-        goto error;
-    }
-
-    // Initialize the device
-    spi_cfg_t msg = {
-        .mode = SPI_MODE_BODER_MSB | SPI_MODE_WORD_WIDTH_8 | SPI_MODE_CPHA_0,
-        .clock_rate = SPI_BUS_SPEED / spi_clkdiv
-    };
-
-    err = devctl(fd, DCMD_SPI_SET_CONFIG, &msg, sizeof(msg), NULL);
-    if (err != EOK) {
-        set_error("SPI is unable to configure to %s. Error=%s", path, strerror(err));
-        goto error;
-    }
-
-    spi_fds[dev] = fd;
-    return EOK;
-
-error:
-    if (fd != -1) close(fd);
-    return err;
-}
