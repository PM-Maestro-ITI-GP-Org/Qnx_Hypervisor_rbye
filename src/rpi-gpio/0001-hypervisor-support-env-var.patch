-PyDoc_STRVAR(smbus_qnx_block_process_call_doc,
-        "block_process_call(address, cmd, data)\n\n"
-        "Writes a command followed by a sequence of bytes to the slave via I2C.\n"
-        "It then reads back a sequence of up to 32 bytes from the slave via I2C.\n"
-        "The first byte of that sequence is always the number of bytes to follow.\n\n"
-        "Arguments:\n"
-        "address - The slave's address as an integer value.\n"
-        "cmd - The command byte to write. An integer in the range [0-255]\n"
-        "data - A list of bytes to write to the slave after the command byte.\n"
-        "       Each element MUST be an integer in the range [0-255]\n"
-        "       The list MUST be at most 32 elements in length.\n\n"
-        "Returns:\n"
-        "A list of integers where each integer is a byte in the range [0-255].\n"
-        "The list will be at most 32 elements in length, as the first byte of data\n"
-        "returned from the slave dictates the length of the list and is not\n"
-        "included in the result.\n");
-static PyObject* smbus_qnx_block_process_call(smbus_qnx_t *self, PyObject *args) {
-    int cmd;
-    PyObject *list;
-    ssize_t len;
-    i2c_srmsg_t msg = {
-        .hdr.slave.fmt = I2C_ADDRFMT_7BIT,
-        .hdr.recv_len = 1+32,
-        .hdr.stop = 0
-    };
-
-    if (!PyArg_ParseTuple(args, "iiO!:write_block_data", &msg.hdr.slave.addr, &cmd, &PyList_Type, &list)) {
-        return NULL;
-    }
-    len = smbus_qnx_parse_list(list, &msg.data[2], sizeof(msg.data)-2);
-    if (len == -1) return NULL;
-
-    msg.data[0] = cmd;
-    msg.data[1] = (uint8_t)len;
-    msg.hdr.send_len = len + 2;
-
-    if (devctl(self->fd, DCMD_I2C_SENDRECV, &msg, sizeof(msg), NULL)) {
-        PyErr_SetFromErrno(PyExc_IOError);
-        return NULL;
-    }
-
-    // The first byte of received data is the number of actual bytes
-    // in the response.
-    // Technically according to the v2 SMBus spec M+N <= 32 where
-    //  M == number of data/payload bytes written
-    //  N == number of data/payload bytes read
-    // I'm not enforcing that, just that M <= 32 && N <= 32
-    return smbus_qnx_make_list(&msg.data[1], msg.data[0], SMBUS_MAX_PAYLOAD);
-}
