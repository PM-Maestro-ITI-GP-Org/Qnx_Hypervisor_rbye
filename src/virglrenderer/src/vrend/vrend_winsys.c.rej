--- src/vrend/vrend_winsys.c
+++ src/vrend/vrend_winsys.c
@@ -60,7 +60,14 @@ int vrend_winsys_init(uint32_t flags, int preferred_fd)
        * If the user specifies a preferred DRM fd and we can't use it, fail. If the user doesn't
        * specify an fd, it's possible to initialize EGL without one.
        */
-      gbm = virgl_gbm_init(preferred_fd);
+      /* QNX: the generic gbm/dri (MESA-LOADER) device query crashes on QNX's DRM.
+       * When surfaceless with no caller-provided fd, skip gbm entirely and use pure
+       * EGL surfaceless (EGL_PLATFORM_SURFACELESS_MESA, or the Screen default display
+       * fallback) -- QNX provides EGL_EXT_platform_base. */
+      if (preferred_fd < 0 && (flags & VIRGL_RENDERER_USE_SURFACELESS))
+         gbm = NULL;
+      else
+         gbm = virgl_gbm_init(preferred_fd);
       if (preferred_fd > 0 && !gbm)
          return -1;
 
